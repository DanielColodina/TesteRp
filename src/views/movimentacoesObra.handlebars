<div class="movimentacoes-obra-container">
    <div class="header-section">
        <h1>📊 Movimentações de Materiais</h1>
        <div class="obra-info">
            <h2>{{obra.nome_obra}}</h2>
            <p class="obra-detalhes">{{obra.endereco}} | Cliente: {{obra.cliente}}</p>
        </div>
        <div class="header-actions">
            <a href="/dashboard/controle-geral/estoque/obra/{{obra.id}}" class="btn-secondary">
                📦 Materiais
            </a>
            <a href="/dashboard/controle-geral/obras" class="btn-secondary">
                ← Voltar às Obras
            </a>
        </div>
    </div>

    <div class="movimentacoes-section">
        <div class="section-header">
            <h3>Registro de Movimentações</h3>
            <div class="action-buttons">
                <button class="btn-primary" onclick="abrirModalEntrada()">➕ Registrar Entrada</button>
                <button class="btn-warning" onclick="abrirModalSaida()">➖ Registrar Saída</button>
            </div>
        </div>

        {{#if movimentacoes.length}}
        <div class="movimentacoes-table-container">
            <table class="movimentacoes-table">
                <thead>
                    <tr>
                        <th>Data</th>
                        <th>Tipo</th>
                        <th>Material</th>
                        <th>Etapa</th>
                        <th>Quantidade</th>
                        <th>Unidade</th>
                        <th>Responsável</th>
                        <th>Motivo</th>
                        <th>Documento</th>
                    </tr>
                </thead>
                <tbody>
                    {{#each movimentacoes}}
                    <tr class="movimentacao-row {{#if (eq tipo 'entrada')}}entrada{{else if (eq tipo 'saida')}}saida{{else}}perda{{/if}}">
                        <td>{{formatDate data_movimentacao}}</td>
                        <td>
                            <span class="tipo-badge {{#if (eq tipo 'entrada')}}tipo-entrada{{else if (eq tipo 'saida')}}tipo-saida{{else}}tipo-perda{{/if}}">
                                {{#if (eq tipo 'entrada')}}📥 Entrada{{else if (eq tipo 'saida')}}📤 Saída{{else}}⚠️ Perda{{/if}}
                            </span>
                        </td>
                        <td class="material-nome">{{material_nome}}</td>
                        <td>{{etapa_obra}}</td>
                        <td class="quantidade {{#if (eq tipo 'saida')}}negativo{{else}}positivo{{/if}}">
                            {{#if (eq tipo 'saida')}}-{{/if}}{{quantidade}}
                        </td>
                        <td>{{unidade}}</td>
                        <td>{{responsavel_nome}}</td>
                        <td>{{motivo}}</td>
                        <td>{{documento}}</td>
                    </tr>
                    {{/each}}
                </tbody>
            </table>
        </div>

        <div class="resumo-movimentacoes">
            <div class="resumo-card">
                <h4>📥 Total de Entradas</h4>
                <span class="resumo-valor entrada">{{totalEntradas movimentacoes}}</span>
            </div>
            <div class="resumo-card">
                <h4>📤 Total de Saídas</h4>
                <span class="resumo-valor saida">{{totalSaidas movimentacoes}}</span>
            </div>
            <div class="resumo-card">
                <h4>⚠️ Total de Perdas</h4>
                <span class="resumo-valor perda">{{totalPerdas movimentacoes}}</span>
            </div>
        </div>
        {{else}}
        <div class="empty-state">
            <p>📋 Nenhuma movimentação registrada para esta obra.</p>
            <p>Registre entradas e saídas de materiais para acompanhar o controle.</p>
        </div>
        {{/if}}
    </div>
</div>

<!-- Modal Registrar Entrada -->
<div id="modalEntrada" class="modal">
    <div class="modal-content">
        <div class="modal-header">
            <h3>📥 Registrar Entrada de Material</h3>
            <span class="close" onclick="fecharModalEntrada()">&times;</span>
        </div>
        <form id="formEntrada" action="/dashboard/controle-geral/estoque/obra/{{obra.id}}/entrada" method="POST">
            <div class="form-group">
                <label for="entrada_material_obra_id">Material:</label>
                <select name="material_obra_id" id="entrada_material_obra_id" required>
                    <option value="">Selecione um material...</option>
                    {{#each materiaisObra}}
                    <option value="{{id}}">{{material_nome}} ({{fase_obra}})</option>
                    {{/each}}
                </select>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label for="entrada_quantidade">Quantidade:</label>
                    <input type="number" name="quantidade" id="entrada_quantidade" step="0.01" min="0.01" required>
                </div>
                <div class="form-group">
                    <label for="entrada_data_movimentacao">Data:</label>
                    <input type="date" name="data_movimentacao" id="entrada_data_movimentacao"
                           value="{{currentDate}}" required>
                </div>
            </div>

            <div class="form-group">
                <label for="entrada_etapa_obra">Etapa da Obra:</label>
                <select name="etapa_obra" id="entrada_etapa_obra">
                    <option value="">Selecione a etapa...</option>
                    <option value="Terraplenagem e Fundações">Terraplenagem e Fundações</option>
                    <option value="Alvenaria Estrutural">Alvenaria Estrutural</option>
                    <option value="Estrutura">Estrutura (Pilares, Vigas e Lajes)</option>
                    <option value="Alvenaria de Vedação">Alvenaria de Vedação</option>
                    <option value="Cobertura">Cobertura</option>
                    <option value="Instalações Elétricas">Instalações Elétricas</option>
                    <option value="Instalações Hidráulicas">Instalações Hidráulicas</option>
                    <option value="Revestimentos e Acabamentos">Revestimentos e Acabamentos</option>
                    <option value="Esquadrias e Serralheria">Esquadrias e Serralheria</option>
                </select>
            </div>

            <div class="form-group">
                <label for="entrada_motivo">Motivo:</label>
                <input type="text" name="motivo" id="entrada_motivo"
                       placeholder="Ex: Entrega inicial, Reposição, etc." required>
            </div>

            <div class="form-group">
                <label for="entrada_documento">Documento (NF, Pedido, etc.):</label>
                <input type="text" name="documento" id="entrada_documento"
                       placeholder="Número da nota fiscal ou documento">
            </div>

            <div class="form-group">
                <label for="entrada_observacoes">Observações:</label>
                <textarea name="observacoes" id="entrada_observacoes" rows="3"
                          placeholder="Observações adicionais..."></textarea>
            </div>

            <div class="modal-actions">
                <button type="button" class="btn-secondary" onclick="fecharModalEntrada()">Cancelar</button>
                <button type="submit" class="btn-primary">Registrar Entrada</button>
            </div>
        </form>
    </div>
</div>

<!-- Modal Registrar Saída -->
<div id="modalSaida" class="modal">
    <div class="modal-content">
        <div class="modal-header">
            <h3>📤 Registrar Saída de Material</h3>
            <span class="close" onclick="fecharModalSaida()">&times;</span>
        </div>
        <form id="formSaida" action="/dashboard/controle-geral/estoque/obra/{{obra.id}}/saida" method="POST">
            <div class="form-group">
                <label for="saida_material_obra_id">Material:</label>
                <select name="material_obra_id" id="saida_material_obra_id" required>
                    <option value="">Selecione um material...</option>
                    {{#each materiaisObra}}
                    <option value="{{id}}">{{material_nome}} ({{fase_obra}})</option>
                    {{/each}}
                </select>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label for="saida_quantidade">Quantidade:</label>
                    <input type="number" name="quantidade" id="saida_quantidade" step="0.01" min="0.01" required>
                </div>
                <div class="form-group">
                    <label for="saida_data_movimentacao">Data:</label>
                    <input type="date" name="data_movimentacao" id="saida_data_movimentacao"
                           value="{{currentDate}}" required>
                </div>
            </div>

            <div class="form-group">
                <label for="saida_etapa_obra">Etapa da Obra:</label>
                <select name="etapa_obra" id="saida_etapa_obra" required>
                    <option value="">Selecione a etapa...</option>
                    <option value="Terraplenagem e Fundações">Terraplenagem e Fundações</option>
                    <option value="Alvenaria Estrutural">Alvenaria Estrutural</option>
                    <option value="Estrutura">Estrutura (Pilares, Vigas e Lajes)</option>
                    <option value="Alvenaria de Vedação">Alvenaria de Vedação</option>
                    <option value="Cobertura">Cobertura</option>
                    <option value="Instalações Elétricas">Instalações Elétricas</option>
                    <option value="Instalações Hidráulicas">Instalações Hidráulicas</option>
                    <option value="Revestimentos e Acabamentos">Revestimentos e Acabamentos</option>
                    <option value="Esquadrias e Serralheria">Esquadrias e Serralheria</option>
                </select>
            </div>

            <div class="form-group">
                <label for="saida_motivo">Motivo:</label>
                <input type="text" name="motivo" id="saida_motivo"
                       placeholder="Ex: Consumo na obra, Perda, etc." required>
            </div>

            <div class="form-group">
                <label for="saida_documento">Documento:</label>
                <input type="text" name="documento" id="saida_documento"
                       placeholder="Referência ou documento relacionado">
            </div>

            <div class="form-group">
                <label for="saida_observacoes">Observações:</label>
                <textarea name="observacoes" id="saida_observacoes" rows="3"
                          placeholder="Observações adicionais..."></textarea>
            </div>

            <div class="modal-actions">
                <button type="button" class="btn-secondary" onclick="fecharModalSaida()">Cancelar</button>
                <button type="submit" class="btn-warning">Registrar Saída</button>
            </div>
        </form>
    </div>
</div>

