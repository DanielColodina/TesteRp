<script>
// Modal functions
function abrirModalEntrada() {
    document.getElementById('modalEntrada').style.display = 'block';
}

function fecharModalEntrada() {
    document.getElementById('modalEntrada').style.display = 'none';
}

function abrirModalSaida() {
    document.getElementById('modalSaida').style.display = 'block';
}

function fecharModalSaida() {
    document.getElementById('modalSaida').style.display = 'none';
}

// Close modals when clicking outside
window.onclick = function(event) {
    const modals = document.querySelectorAll('.modal');
    modals.forEach(modal => {
        if (event.target === modal) {
            modal.style.display = 'none';
        }
    });
}

// Helper functions for Handlebars
function formatDate(dateString) {
    const date = new Date(dateString);
    return date.toLocaleDateString('pt-BR');
}

function totalEntradas(movimentacoes) {
    return movimentacoes
        .filter(m => m.tipo === 'entrada')
        .reduce((total, m) => total + parseFloat(m.quantidade), 0)
        .toFixed(2);
}

function totalSaidas(movimentacoes) {
    return movimentacoes
        .filter(m => m.tipo === 'saida')
        .reduce((total, m) => total + parseFloat(m.quantidade), 0)
        .toFixed(2);
}

function totalPerdas(movimentacoes) {
    return movimentacoes
        .filter(m => m.tipo === 'perda')
        .reduce((total, m) => total + parseFloat(m.quantidade), 0)
        .toFixed(2);
}

// Make functions available to Handlebars
if (typeof Handlebars !== 'undefined') {
    Handlebars.registerHelper('formatDate', formatDate);
    Handlebars.registerHelper('totalEntradas', totalEntradas);
    Handlebars.registerHelper('totalSaidas', totalSaidas);
    Handlebars.registerHelper('totalPerdas', totalPerdas);
    Handlebars.registerHelper('eq', function(a, b) { return a === b; });
}
</script>