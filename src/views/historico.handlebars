<div class="content-wrapper">
  <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px;">
    <h1>📜 Histórico Completo de Mudanças</h1>
    <a href="/dashboard" class="btn-voltar">← Voltar</a>
  </div>

  {{#if historico}}
    <div style="background: rgba(59, 130, 246, 0.1); padding: 20px; border-radius: 8px; border: 2px solid #3b82f6;">
      <p style="text-align: center; color: #0ea5e9; margin-bottom: 20px;">Total de mudanças: <strong>{{historico.length}}</strong></p>
      
      <ul style="list-style: none; padding: 0;">
        {{#each historico}}
          <li style="background: rgba(0, 0, 0, 0.3); padding: 15px; margin: 12px 0; border-radius: 6px; border-left: 4px solid #3b82f6;">
            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 15px; margin-bottom: 10px;">
              <div>
                <strong style="color: #3b82f6;">Usuário:</strong>
                <p style="margin: 5px 0; color: #e2e8f0;">{{usuario_nome}}</p>
              </div>
              <div>
                <strong style="color: #3b82f6;">Obra:</strong>
                <p style="margin: 5px 0; color: #e2e8f0;">{{obra}}</p>
              </div>
              <div>
                <strong style="color: #3b82f6;">Tipo:</strong>
                <p style="margin: 5px 0; color: #60a5fa;">{{tipo}}</p>
              </div>
              <div>
                <strong style="color: #3b82f6;">Admin Responsável:</strong>
                <p style="margin: 5px 0; color: #e2e8f0;">{{admin_nome}}</p>
              </div>
            </div>
            
            <div style="background: rgba(59, 130, 246, 0.2); padding: 10px; border-radius: 4px; margin: 10px 0;">
              <strong style="color: #60a5fa;">📝 Descrição:</strong>
              <p style="margin: 5px 0; color: #e2e8f0;">{{descricao}}</p>
            </div>
            
            <small style="color: #94a3b8; display: block;">📅 {{created_at}}</small>
          </li>
        {{/each}}
      </ul>
    </div>
  {{else}}
    <div class="error-message">
      <p style="text-align: center;">Nenhum histórico de mudanças encontrado.</p>
    </div>
  {{/if}}

  <div style="text-align: center; margin-top: 30px;">
    <a href="/dashboard/progresso" class="btn-voltar">← Voltar para Dashboard</a>
  </div>
</div>


