<div class="content-wrapper">
  <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px;">
    <h1>📊 Dashboard de Progresso das Obras</h1>
    <a href="/dashboard" class="btn-voltar">← Voltar</a>
  </div>

  <!-- ESTATÍSTICAS GERAIS -->
  <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 20px; margin-bottom: 40px;">
    <div style="background: rgba(56, 189, 248, 0.1); padding: 20px; border-radius: 8px; border-left: 4px solid #38bdf8;">
      <h3 style="color: #38bdf8; margin: 0 0 10px 0;">📈 Progresso Médio</h3>
      <p style="font-size: 32px; font-weight: bold; color: #0ea5e9; margin: 0;">{{progressoMedio}}%</p>
    </div>

    <div style="background: rgba(16, 185, 129, 0.1); padding: 20px; border-radius: 8px; border-left: 4px solid #10b981;">
      <h3 style="color: #10b981; margin: 0 0 10px 0;">✅ Obras Completas</h3>
      <p style="font-size: 32px; font-weight: bold; color: #10b981; margin: 0;">{{obrasCompletas}} / {{totalObras}}</p>
    </div>

    <div style="background: rgba(59, 130, 246, 0.1); padding: 20px; border-radius: 8px; border-left: 4px solid #3b82f6;">
      <h3 style="color: #3b82f6; margin: 0 0 10px 0;">🏗️ Total de Obras</h3>
      <p style="font-size: 32px; font-weight: bold; color: #3b82f6; margin: 0;">{{totalObras}}</p>
    </div>
  </div>


  <!-- TABELA DE PROGRESSO -->
  <div style="background: rgba(56, 189, 248, 0.1); padding: 20px; border-radius: 8px; border: 2px solid #38bdf8; margin-bottom: 40px;">
    <h2 style="margin-top: 0;">🔄 Progresso por Obra</h2>
    
    {{#if checklists}}
      <table class="table-users" style="width: 100%; margin-top: 20px;">
        <thead>
          <tr>
            <th>ID Usuário</th>
            <th>Nome</th>
            <th>Obra</th>
            <th>Uso do Solo</th>
            <th>Licença</th>
            <th>Condomínio</th>
            <th>Habite-se</th>
            <th>Averbação</th>
            <th>Vistoria</th>
            <th>Progresso</th>
            <th>Última Atualização</th>
          </tr>
        </thead>
        <tbody>
          {{#each checklists}}
            <tr>
              <td>{{usuario_id}}</td>
              <td>{{nome}}</td>
              <td>{{obra}}</td>
              <td>
                {{#if (eq uso_solo 'Feito')}}
                  <span style="color: #10b981; font-weight: bold;">✅ Feito</span>
                {{else if (eq uso_solo 'Andamento')}}
                  <span style="color: #f59e0b; font-weight: bold;">⏳ Andamento</span>
                {{else if (eq uso_solo 'Nao Tem')}}
                  <span style="color: #ef4444; font-weight: bold;">⏸️ Não Tem</span>
                {{else}}
                  <span style="color: #6b7280;">{{uso_solo}}</span>
                {{/if}}
              </td>
              <td>
                {{#if (eq licenca 'Feito')}}
                  <span style="color: #10b981; font-weight: bold;">✅ Feito</span>
                {{else if (eq licenca 'Andamento')}}
                  <span style="color: #f59e0b; font-weight: bold;">⏳ Andamento</span>
                {{else if (eq licenca 'Nao Tem')}}
                  <span style="color: #ef4444; font-weight: bold;">⏸️ Não Tem</span>
                {{else}}
                  <span style="color: #6b7280;">{{licenca}}</span>
                {{/if}}
              </td>
              <td>
                {{#if (eq condominio 'Feito')}}
                  <span style="color: #10b981; font-weight: bold;">✅ Feito</span>
                {{else if (eq condominio 'Andamento')}}
                  <span style="color: #f59e0b; font-weight: bold;">⏳ Andamento</span>
                {{else if (eq condominio 'Nao Tem')}}
                  <span style="color: #ef4444; font-weight: bold;">⏸️ Não Tem</span>
                {{else}}
                  <span style="color: #6b7280;">{{condominio}}</span>
                {{/if}}
              </td>
              <td>
                {{#if (eq habite_se 'Feito')}}
                  <span style="color: #10b981; font-weight: bold;">✅ Feito</span>
                {{else if (eq habite_se 'Andamento')}}
                  <span style="color: #f59e0b; font-weight: bold;">⏳ Andamento</span>
                {{else if (eq habite_se 'Nao Tem')}}
                  <span style="color: #ef4444; font-weight: bold;">⏸️ Não Tem</span>
                {{else}}
                  <span style="color: #6b7280;">{{habite_se}}</span>
                {{/if}}
              </td>
              <td>
                {{#if (eq averbacao 'Feito')}}
                  <span style="color: #10b981; font-weight: bold;">✅ Feito</span>
                {{else if (eq averbacao 'Andamento')}}
                  <span style="color: #f59e0b; font-weight: bold;">⏳ Andamento</span>
                {{else if (eq averbacao 'Nao Tem')}}
                  <span style="color: #ef4444; font-weight: bold;">⏸️ Não Tem</span>
                {{else}}
                  <span style="color: #6b7280;">{{averbacao}}</span>
                {{/if}}
              </td>
              <td>
                {{#if (eq vistoria 'Feito')}}
                  <span style="color: #10b981; font-weight: bold;">✅ Feito</span>
                {{else if (eq vistoria 'Andamento')}}
                  <span style="color: #f59e0b; font-weight: bold;">⏳ Andamento</span>
                {{else if (eq vistoria 'Nao Tem')}}
                  <span style="color: #ef4444; font-weight: bold;">⏸️ Não Tem</span>
                {{else}}
                  <span style="color: #6b7280;">{{vistoria}}</span>
                {{/if}}
              </td>
              <td>
                <div style="width: 100%; background: #1e293b; border-radius: 4px; overflow: hidden; height: 20px;">
                  <div style="width: {{progresso}}%; height: 100%; background: linear-gradient(90deg, #10b981 0%, #059669 100%); display: flex; align-items: center; justify-content: center; color: white; font-size: 10px; font-weight: bold;">
                    {{progresso}}%
                  </div>
                </div>
              </td>
              <td>{{updated_at}}</td>
            </tr>
          {{/each}}
        </tbody>
      </table>
    {{else}}
      <p style="text-align: center; color: #0ea5e9;">Nenhuma obra cadastrada.</p>
    {{/if}}
  </div>

  <!-- HISTÓRICO RECENTE -->
  <div style="background: rgba(59, 130, 246, 0.1); padding: 20px; border-radius: 8px; border: 2px solid #3b82f6; margin-bottom: 40px;">
    <h2 style="margin-top: 0;">📜 Histórico Recente</h2>
    
    {{#if historicoRecente}}
      <ul style="list-style: none; padding: 0;">
        {{#each historicoRecente}}
          <li style="background: rgba(0, 0, 0, 0.2); padding: 12px; margin: 10px 0; border-radius: 6px; border-left: 3px solid #3b82f6;">
            <strong style="color: #38bdf8;">{{usuario_nome}}</strong> - {{obra}}
            <br>
            <span style="color: #0ea5e9;">{{tipo}}</span>: {{descricao}}
            <br>
            <small style="color: #94a3b8;">Por: {{admin_nome}} | {{created_at}}</small>
          </li>
        {{/each}}
      </ul>
    {{else}}
      <p style="text-align: center; color: #0ea5e9;">Nenhum histórico registrado.</p>
    {{/if}}
  </div>

  <!-- LOGS DE AUDITORIA -->
  <div style="background: rgba(239, 68, 68, 0.1); padding: 20px; border-radius: 8px; border: 2px solid #ef4444;">
    <h2 style="margin-top: 0;">🔒 Últimos Logs de Auditoria</h2>
    
    {{#if auditoria}}
      <ul style="list-style: none; padding: 0;">
        {{#each auditoria}}
          <li style="background: rgba(0, 0, 0, 0.2); padding: 12px; margin: 10px 0; border-radius: 6px; border-left: 3px solid #ef4444;">
            <strong style="color: #f87171;">{{acao}}</strong>
            <br>
            <span style="color: #fb7185;">Usuário: {{usuario_nome}} | Admin: {{admin_nome}}</span>
            <br>
            <small style="color: #94a3b8;">Campo: {{campo}} | {{created_at}}</small>
          </li>
        {{/each}}
      </ul>
    {{else}}
      <p style="text-align: center; color: #ef4444;">Nenhuma auditoria registrada.</p>
    {{/if}}
  </div>

  <!-- Link para ver auditoria completa -->
  <div style="text-align: center; margin-top: 30px;">
    <a href="/dashboard/auditoria" style="display: inline-block; padding: 12px 24px; background: #38bdf8; color: white; text-decoration: none; border-radius: 6px; margin-right: 10px;">🔒 Ver Auditoria Completa</a>
    <a href="/dashboard/historico" style="display: inline-block; padding: 12px 24px; background: #10b981; color: white; text-decoration: none; border-radius: 6px;">📜 Ver Histórico Completo</a>
  </div>
</div>

{{!-- Helper para comparar valores --}}





  <!-- Link para ver auditoria completa -->
  <div style="text-align: center; margin-top: 30px;">
    <a href="/dashboard/auditoria" style="display: inline-block; padding: 12px 24px; background: #38bdf8; color: white; text-decoration: none; border-radius: 6px; margin-right: 10px;">🔒 Ver Auditoria Completa</a>
    <a href="/dashboard/historico" style="display: inline-block; padding: 12px 24px; background: #10b981; color: white; text-decoration: none; border-radius: 6px;">📜 Ver Histórico Completo</a>
  </div>
</div>

{{!-- Helper para comparar valores --}}




<script>
  Handlebars.registerHelper('eq', function(a, b) {
    return a === b;
  });
</script>


