    margin: 0 0 10px 0;
    font-size: 2.2rem;
}

.obra-info h2 {
    margin: 0 0 5px 0;
    font-size: 1.5rem;
    opacity: 0.95;
}

.obra-detalhes {
    margin: 0;
    opacity: 0.8;
    font-size: 1rem;
}

.header-actions {
    margin-top: 20px;
    display: flex;
