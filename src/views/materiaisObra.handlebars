</style>

<script>
// Filtro por etapas
document.querySelectorAll('.etapa-btn').forEach(btn => {
    btn.addEventListener('click', function() {
        const etapa = this.dataset.etapa;

        // Toggle active class
        document.querySelectorAll('.etapa-btn').forEach(b => b.classList.remove('active'));
        this.classList.add('active');

        // Filter table rows
        document.querySelectorAll('.material-row').forEach(row => {
            if (etapa === 'todas' || row.dataset.fase === etapa) {
                row.style.display = '';
            } else {
                row.style.display = 'none';
            }
        });
    });
});

// Modal functions
function abrirModalAdicionar() {
    document.getElementById('modalAdicionar').style.display = 'block';
}

function fecharModal() {
    document.getElementById('modalAdicionar').style.display = 'none';
}

function fecharModalEditar() {
    document.getElementById('modalEditar').style.display = 'none';
}

function editarMaterial(materialObraId) {
    // Buscar dados do material via AJAX ou usar dados da tabela
    const row = document.querySelector(`[data-material-obra-id="${materialObraId}"]`);
    if (!row) return;

    // Preencher modal de edição
    document.getElementById('edit_material_obra_id').value = materialObraId;
    // ... preencher outros campos

    document.getElementById('modalEditar').style.display = 'block';
}

function removerMaterial(materialObraId) {
    if (confirm('Tem certeza que deseja remover este material da obra?')) {
        const form = document.createElement('form');
        form.method = 'POST';
        form.action = `/dashboard/controle-geral/estoque/obra/{{obra.id}}/remover/${materialObraId}`;

        document.body.appendChild(form);
        form.submit();
    }
}

// Form editar
document.getElementById('formEditarMaterial').addEventListener('submit', function(e) {
    e.preventDefault();

    const materialObraId = document.getElementById('edit_material_obra_id').value;
    const formData = new FormData(this);

    // Submit form
    const form = document.createElement('form');
    form.method = 'POST';
    form.action = `/dashboard/controle-geral/estoque/obra/{{obra.id}}/editar/${materialObraId}`;

    for (let [key, value] of formData) {
        const input = document.createElement('input');
        input.type = 'hidden';
        input.name = key;
        input.value = value;
        form.appendChild(input);
    }

    document.body.appendChild(form);
    form.submit();
});

// Close modals when clicking outside
window.onclick = function(event) {
    const modals = document.querySelectorAll('.modal');
    modals.forEach(modal => {
        if (event.target === modal) {
            modal.style.display = 'none';
        }
    });
}
</script>