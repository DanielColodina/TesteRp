<div class="materiais-obra-container">
    <div class="header-section">
        <h1>📦 Materiais da Obra</h1>
        <div class="obra-info">
            <h2>{{obra.nome_obra}}</h2>
            <p class="obra-detalhes">{{obra.endereco}} | Cliente: {{obra.cliente}}</p>
        </div>
        <div class="header-actions">
            <a href="/dashboard/controle-geral/estoque/obra/{{obra.id}}/movimentacoes" class="btn-primary">
                📊 Movimentações
            </a>
            <a href="/dashboard/controle-geral/obras" class="btn-secondary">
                ← Voltar às Obras
            </a>
        </div>
    </div>

    {{#if etapas.length}}
    <div class="etapas-nav">
        <h3>Etapas da Obra:</h3>
        <div class="etapas-list">
            {{#each etapas}}
            <button class="etapa-btn" data-etapa="{{this}}">{{this}}</button>
            {{/each}}
        </div>
    </div>
    {{/if}}

    <div class="materiais-section">
        <div class="section-header">
            <h3>Catálogo de Materiais</h3>
            <button class="btn-primary" onclick="abrirModalAdicionar()">➕ Adicionar Material</button>
        </div>

        {{#if materiais.length}}
        <div class="materiais-table-container">
            <table class="materiais-table">
                <thead>
                    <tr>
                        <th>Categoria</th>
                        <th>Subcategoria</th>
                        <th>Nome do Item</th>
                        <th>Descrição Técnica</th>
                        <th>Unidade</th>
                        <th>Qtde Estimada Total</th>
                        <th>Qtde Inicial Existente</th>
                        <th>Saldo Atual</th>
                        <th>Fase da Obra</th>
                        <th>Ações</th>
                    </tr>
                </thead>
                <tbody>
                    {{#each materiais}}
                    <tr class="material-row" data-fase="{{fase_obra}}">
                        <td>{{categoria}}</td>
                        <td>{{subcategoria}}</td>
                        <td class="material-nome">{{material_nome}}</td>
                        <td class="material-descricao">{{descricao}}</td>
                        <td>{{unidade}}</td>
                        <td class="quantidade">{{quantidade_estimada}}</td>
                        <td class="quantidade">{{quantidade_inicial}}</td>
                        <td class="saldo-atual {{#if (lt saldo_atual 0.1)}}saldo-baixo{{/if}}">
                            {{saldo_atual}}
                        </td>
                        <td>{{fase_obra}}</td>
                        <td class="acoes">
                            <button class="btn-edit" onclick="editarMaterial({{id}})">✏️</button>
                            <button class="btn-delete" onclick="removerMaterial({{id}})">🗑️</button>
                        </td>
                    </tr>
                    {{/each}}
                </tbody>
            </table>
        </div>
        {{else}}
        <div class="empty-state">
            <p>📋 Nenhum material cadastrado para esta obra.</p>
            <p>Adicione materiais do catálogo para começar o controle.</p>
        </div>
        {{/if}}
    </div>
</div>

<!-- Modal Adicionar Material -->
<div id="modalAdicionar" class="modal">
    <div class="modal-content">
        <div class="modal-header">
            <h3>Adicionar Material à Obra</h3>
            <span class="close" onclick="fecharModal()">&times;</span>
        </div>
        <form id="formAdicionarMaterial" action="/dashboard/controle-geral/estoque/obra/{{obra.id}}/adicionar" method="POST">
            <div class="form-group">
                <label for="material_id">Material:</label>
                <select name="material_id" id="material_id" required>
                    <option value="">Selecione um material...</option>
                    {{#each materiaisDisponiveis}}
                    <option value="{{id}}">{{nome}} ({{unidade}})</option>
                    {{/each}}
                </select>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label for="quantidade_estimada">Quantidade Estimada Total:</label>
                    <input type="number" name="quantidade_estimada" id="quantidade_estimada" step="0.01" required>
                </div>
                <div class="form-group">
                    <label for="quantidade_inicial">Quantidade Inicial Existente:</label>
                    <input type="number" name="quantidade_inicial" id="quantidade_inicial" step="0.01" value="0">
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label for="fase_obra">Fase da Obra:</label>
                    <select name="fase_obra" id="fase_obra" required>
                        <option value="">Selecione a fase...</option>
                        <option value="Terraplenagem e Fundações">Terraplenagem e Fundações</option>
                        <option value="Alvenaria Estrutural">Alvenaria Estrutural</option>
                        <option value="Estrutura">Estrutura (Pilares, Vigas e Lajes)</option>
                        <option value="Alvenaria de Vedação">Alvenaria de Vedação</option>
                        <option value="Cobertura">Cobertura</option>
                        <option value="Instalações Elétricas">Instalações Elétricas</option>
                        <option value="Instalações Hidráulicas">Instalações Hidráulicas</option>
                        <option value="Revestimentos e Acabamentos">Revestimentos e Acabamentos</option>
                        <option value="Esquadrias e Serralheria">Esquadrias e Serralheria</option>
                    </select>
                </div>
                <div class="form-group">
                    <label for="categoria">Categoria:</label>
                    <select name="categoria" id="categoria">
                        <option value="">Selecione...</option>
                        <option value="Materiais Básicos">Materiais Básicos</option>
                        <option value="Estrutura">Estrutura</option>
                        <option value="Alvenaria">Alvenaria</option>
                        <option value="Instalações">Instalações</option>
                        <option value="Acabamentos">Acabamentos</option>
                        <option value="Acessórios">Acessórios</option>
                    </select>
                </div>
            </div>

            <div class="form-group">
                <label for="subcategoria">Subcategoria:</label>
                <input type="text" name="subcategoria" id="subcategoria" placeholder="Ex: Cerâmicos, Elétricos, etc.">
            </div>

            <div class="modal-actions">
                <button type="button" class="btn-secondary" onclick="fecharModal()">Cancelar</button>
                <button type="submit" class="btn-primary">Adicionar Material</button>
            </div>
        </form>
    </div>
</div>

<!-- Modal Editar Material -->
<div id="modalEditar" class="modal">
    <div class="modal-content">
        <div class="modal-header">
            <h3>Editar Material da Obra</h3>
            <span class="close" onclick="fecharModalEditar()">&times;</span>
        </div>
        <form id="formEditarMaterial">
            <input type="hidden" id="edit_material_obra_id" name="material_obra_id">

            <div class="form-row">
                <div class="form-group">
                    <label for="edit_quantidade_estimada">Quantidade Estimada Total:</label>
                    <input type="number" name="quantidade_estimada" id="edit_quantidade_estimada" step="0.01" required>
                </div>
                <div class="form-group">
                    <label for="edit_quantidade_inicial">Quantidade Inicial Existente:</label>
                    <input type="number" name="quantidade_inicial" id="edit_quantidade_inicial" step="0.01" required>
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label for="edit_fase_obra">Fase da Obra:</label>
                    <select name="fase_obra" id="edit_fase_obra" required>
                        <option value="Terraplenagem e Fundações">Terraplenagem e Fundações</option>
                        <option value="Alvenaria Estrutural">Alvenaria Estrutural</option>
                        <option value="Estrutura">Estrutura (Pilares, Vigas e Lajes)</option>
                        <option value="Alvenaria de Vedação">Alvenaria de Vedação</option>
                        <option value="Cobertura">Cobertura</option>
                        <option value="Instalações Elétricas">Instalações Elétricas</option>
                        <option value="Instalações Hidráulicas">Instalações Hidráulicas</option>
                        <option value="Revestimentos e Acabamentos">Revestimentos e Acabamentos</option>
                        <option value="Esquadrias e Serralheria">Esquadrias e Serralheria</option>
                    </select>
                </div>
                <div class="form-group">
                    <label for="edit_categoria">Categoria:</label>
                    <select name="categoria" id="edit_categoria">
                        <option value="">Selecione...</option>
                        <option value="Materiais Básicos">Materiais Básicos</option>
                        <option value="Estrutura">Estrutura</option>
                        <option value="Alvenaria">Alvenaria</option>
                        <option value="Instalações">Instalações</option>
                        <option value="Acabamentos">Acabamentos</option>
                        <option value="Acessórios">Acessórios</option>
                    </select>
                </div>
            </div>

            <div class="form-group">
                <label for="edit_subcategoria">Subcategoria:</label>
                <input type="text" name="subcategoria" id="edit_subcategoria">
            </div>

            <div class="modal-actions">
                <button type="button" class="btn-secondary" onclick="fecharModalEditar()">Cancelar</button>
                <button type="submit" class="btn-primary">Salvar Alterações</button>
            </div>
        </form>
    </div>
</div>

<style>
